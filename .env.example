# ── Telegram ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Score thresholds (default 65 out of 150 for all assets) ──────
STRONG_SCORE=65      # NSE India
GOLD_SCORE=65        # Gold (XAUUSD)
BTC_SCORE=65         # Bitcoin (BTCUSDT)

# ── NSE scan settings ─────────────────────────────────────────────
NSE_WATCHLIST=RELIANCE,TCS,INFY,HDFCBANK,ICICIBANK,AXISBANK,SBIN,BAJFINANCE,WIPRO,LT

# ── Capital & risk ────────────────────────────────────────────────
CAPITAL=100000       # Rs — used for position sizing
RISK_PCT=0.005       # 0.5% per trade

# ── Dashboard ─────────────────────────────────────────────────────
PORT=5000

# ── GitHub raw URL (Render fallback to read signals_log.json) ─────
SIGNALS_JSON_URL=https://raw.githubusercontent.com/YOUR_USERNAME/YOUR_REPO/main/signals_log.json
